  status          EgiszDocStatus @default(DRAFT)
  xmlPayload      String?
  errorMessage    String?
  sentAt          DateTime?
  acceptedAt      DateTime?
  externalId      String?
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  patient         Patient        @relation(fields: [patientId], references: [id])

  @@map("egisz_documents")
}

