generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id              String           @id @default(uuid())
  name            String
  legalName       String?
  inn             String?
  address         String?
  phone           String?
  email           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  branches        Branch[]
  settings        ClinicSettings?
  patients        Patient[]
  specializations Specialization[]
  userClinics     UserClinic[]
  widgetSettings  WidgetSettings?
  subscription    Subscription?

  @@map("core_clinics")
}

model ClinicSettings {
  id                         String   @id @default(uuid())
  clinicId                   String   @unique
  timezone                   String   @default("Europe/Moscow")
  currency                   String   @default("RUB")
  dateFormat                 String   @default("DD.MM.YYYY")
  timeFormat                 String   @default("24h")
  appointmentDurationDefault Int      @default(30)
  workingHoursStart          String   @default("09:00")
  workingHoursEnd            String   @default("21:00")
  updatedAt                  DateTime @updatedAt
  clinic                     Clinic   @relation(fields: [clinicId], references: [id])

  @@map("core_clinic_settings")
}

model WidgetSettings {
  clinicId            String   @id
  apiKey              String   @unique @default(uuid())
  allowedDomains      String[]
  enabled             Boolean  @default(false)
  theme               Json?
  showDoctors         Boolean  @default(true)
  availableServiceIds String[]
  updatedAt           DateTime @updatedAt
  clinic              Clinic   @relation(fields: [clinicId], references: [id])

  @@map("core_widget_settings")
}

model Branch {
  id                   String                @id @default(uuid())
  clinicId             String
  name                 String
  shortCode            String?
  address              String?
  phone                String?
  color                String?
  isMain               Boolean               @default(false)
  isActive             Boolean               @default(true)
  workingHoursStart    String?
  workingHoursEnd      String?
  isDeleted            Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  appointments         Appointment[]
  doctorSchedules      DoctorSchedule[]
  scheduleExceptions   ScheduleException[]
  serviceBranchPrices  ServiceBranchPrice[]
  workingHours         BranchWorkingHours[]
  clinic               Clinic                @relation(fields: [clinicId], references: [id])
  calls                Call[]
  rooms                Room[]
  userBranches         UserBranch[]
  cashFlowTransactions CashFlowTransaction[]
  workTimes            EmployeeWorkTime[]
  materialStock        MaterialStock[]
  stockMovements       StockMovement[]
  stockReceipts        StockReceipt[]

  @@map("core_branches")
}

model BranchWorkingHours {
  id        String  @id @default(uuid())
  branchId  String
  dayOfWeek Int
  isOpen    Boolean @default(true)
  startTime String  @default("09:00")
  endTime   String  @default("21:00")
  branch    Branch  @relation(fields: [branchId], references: [id])

  @@unique([branchId, dayOfWeek])
  @@map("core_branch_working_hours")
}

model Room {
  id           String        @id @default(uuid())
  clinicId     String
  branchId     String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  branch       Branch        @relation(fields: [branchId], references: [id])

  @@map("core_rooms")
}

model User {
  id                     String                   @id @default(uuid())
  email                  String                   @unique
  password               String
  name                   String
  phone                  String?
  avatarUrl              String?
  failedAttempts         Int                      @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  isDeleted              Boolean                  @default(false)
  deletedAt              DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  birthDate              DateTime?
  title                  String?
  createdAppointments    Appointment[]            @relation("CreatedAppointments")
  appointments           Appointment[]            @relation("DoctorAppointments")
  doctorSchedules        DoctorSchedule[]
  uploadedFiles          File[]
  medicalRecords         MedicalRecord[]
  patientDiaries         PatientDiary[]
  scheduleExceptions     ScheduleException[]
  treatmentPlans         TreatmentPlan[]
  handledCalls           Call[]
  assignedTasks          ClinicTask[]             @relation("AssignedTasks")
  createdTasks           ClinicTask[]             @relation("CreatedTasks")
  issuedDocuments        IssuedDocument[]
  patientComments        PatientComment[]
  patientDoctors         PatientDoctor[]
  userBranches           UserBranch[]
  userClinics            UserClinic[]
  balanceTransactions    BalanceTransaction[]
  bonusTransactions      BonusTransaction[]
  cashFlowTransactions   CashFlowTransaction[]
  createdConsultInvoices ConsultInvoice[]
  createdInvoices        Invoice[]
  receivedPayments       Payment[]
  createdDoctorPayments  DoctorPayment[]          @relation("DoctorPaymentCreatedBy")
  doctorPayments         DoctorPayment[]          @relation("DoctorPaymentUser")
  salarySettings         EmployeeSalarySettings[]
  workTimes              EmployeeWorkTime[]
  stockMovements         StockMovement[]
  createdStockReceipts   StockReceipt[]
  createdLabInvoices     LabInvoice[]
  createdLabOrders       LabOrder[]
  reminders              Reminder[]

  @@map("core_users")
}

model UserClinic {
  id               String          @id @default(uuid())
  userId           String
  clinicId         String
  role             UserRole        @default(DOCTOR)
  isOwner          Boolean         @default(false)
  specializationId String?
  color            String?
  isActive         Boolean         @default(true)
  isDeleted        Boolean         @default(false)
  deletedAt        DateTime?
  joinedAt         DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  clinic           Clinic          @relation(fields: [clinicId], references: [id])
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  user             User            @relation(fields: [userId], references: [id])

  @@unique([userId, clinicId])
  @@map("core_user_clinics")
}

model UserBranch {
  userId      String
  branchId    String
  isDefault   Boolean @default(false)
  accessLevel String  @default("full")
  branch      Branch  @relation(fields: [branchId], references: [id])
  user        User    @relation(fields: [userId], references: [id])

  @@id([userId, branchId])
  @@map("core_user_branches")
}

model Specialization {
  id             String                   @id @default(uuid())
  clinicId       String
  name           String
  sortOrder      Int                      @default(0)
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  patientDoctors PatientDoctor[]
  clinic         Clinic                   @relation(fields: [clinicId], references: [id])
  userClinics    UserClinic[]
  salarySettings EmployeeSalarySettings[]

  @@map("core_specializations")
}

model Patient {
  id                  String                   @id @default(uuid())
  clinicId            String
  firstName           String
  lastName            String
  middleName          String?
  birthDate           DateTime?
  allergies           String?
  notes               String?
  referralSource      PatientReferralSource?
  homeBranchId        String?
  createdByUserId     String?
  isDeleted           Boolean                  @default(false)
  deletedAt           DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  inn                 String?
  loyaltyTierId       String?
  passportNumber      String?
  passportSeries      String?
  patientNumber       String?
  snils               String?
  gender              Gender?
  appointments        Appointment[]
  dentalChart         DentalChart[]
  files               File[]
  medicalRecords      MedicalRecord[]
  patientDiaries      PatientDiary[]
  treatmentPlans      TreatmentPlan[]
  widgetBookings      WidgetBooking[]
  calls               Call[]
  clinicTasks         ClinicTask[]
  issuedDocuments     IssuedDocument[]
  comments            PatientComment[]
  contacts            PatientContact[]
  doctors             PatientDoctor[]
  groupMemberships    PatientGroupMember[]
  labels              PatientLabelAssignment[]
  relatives           PatientRelative[]        @relation("PatientRelatives")
  relativeOf          PatientRelative[]        @relation("RelativeAsPatient")
  clinic              Clinic                   @relation(fields: [clinicId], references: [id])
  loyaltyTier         LoyaltyTier?             @relation(fields: [loyaltyTierId], references: [id])
  egiszDocuments      EgiszDocument[]
  balanceTransactions BalanceTransaction[]
  balance             Balance?
  bonusTransactions   BonusTransaction[]
  bonuses             Bonus?
  consultInvoices     ConsultInvoice[]
  invoices            Invoice[]
  promotionUsages     PromotionUsage[]
  insurances          PatientInsurance[]
  labOrders           LabOrder[]
  notificationLogs    NotificationLog[]
  reminders           Reminder[]

  @@unique([clinicId, patientNumber])
  @@map("core_patients")
}

model PatientContact {
  id        String      @id @default(uuid())
  clinicId  String
  patientId String
  type      ContactType
  value     String
  label     String?
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())
  patient   Patient     @relation(fields: [patientId], references: [id])

  @@map("core_patient_contacts")
}

model PatientComment {
  id        String   @id @default(uuid())
  clinicId  String
  patientId String
  authorId  String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  patient   Patient  @relation(fields: [patientId], references: [id])

  @@map("core_patient_comments")
}

model PatientLabel {
  id          String                   @id @default(uuid())
  clinicId    String
  name        String
  color       String                   @default("#14919B")
  textColor   String                   @default("#ffffff")
  isSystem    Boolean                  @default(false)
  createdAt   DateTime                 @default(now())
  assignments PatientLabelAssignment[]

  @@unique([clinicId, name])
  @@map("core_patient_labels")
}

model PatientLabelAssignment {
  id         String       @id @default(uuid())
  clinicId   String
  patientId  String
  labelId    String
  assignedAt DateTime     @default(now())
  label      PatientLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  patient    Patient      @relation(fields: [patientId], references: [id])

  @@unique([patientId, labelId])
  @@map("core_patient_label_assignments")
}

model PatientDoctor {
  id               String         @id @default(uuid())
  clinicId         String
  patientId        String
  doctorId         String
  specializationId String
  isActive         Boolean        @default(true)
  assignedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  doctor           User           @relation(fields: [doctorId], references: [id])
  patient          Patient        @relation(fields: [patientId], references: [id])
  specialization   Specialization @relation(fields: [specializationId], references: [id])

  @@map("core_patient_doctors")
}

model PatientRelative {
  id                String       @id @default(uuid())
  clinicId          String
  patientId         String
  relativeType      RelativeType
  name              String
  phone             String?
  email             String?
  isGuardian        Boolean      @default(false)
  notes             String?
  relativePatientId String?
  createdAt         DateTime     @default(now())
  patient           Patient      @relation("PatientRelatives", fields: [patientId], references: [id])
  relativePatient   Patient?     @relation("RelativeAsPatient", fields: [relativePatientId], references: [id])

  @@map("core_patient_relatives")
}

model PatientGroup {
  id            String               @id @default(uuid())
  clinicId      String
  name          String
  discountType  DiscountType         @default(PERCENT)
  discountValue Decimal              @db.Decimal(5, 2)
  color         String?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  members       PatientGroupMember[]

  @@map("core_patient_groups")
}

model PatientGroupMember {
  groupId   String
  patientId String
  addedAt   DateTime     @default(now())
  group     PatientGroup @relation(fields: [groupId], references: [id])
  patient   Patient      @relation(fields: [patientId], references: [id])

  @@id([groupId, patientId])
  @@map("core_patient_group_members")
}

model Call {
  id              String        @id @default(uuid())
  clinicId        String
  branchId        String?
  patientId       String?
  userId          String?
  direction       CallDirection
  result          CallResult
  phone           String
  durationSeconds Int?
  notes           String?
  recordingUrl    String?
  calledAt        DateTime
  createdAt       DateTime      @default(now())
  branch          Branch?       @relation(fields: [branchId], references: [id])
  patient         Patient?      @relation(fields: [patientId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])

  @@map("core_calls")
}

model IssuedDocument {
  id              String    @id @default(uuid())
  clinicId        String
  patientId       String?
  docType         String
  docNumber       String?
  issuedAt        DateTime  @default(now())
  validTo         DateTime?
  fileKey         String?
  notes           String?
  createdByUserId String?
  createdBy       User?     @relation(fields: [createdByUserId], references: [id])
  patient         Patient?  @relation(fields: [patientId], references: [id])

  @@map("core_issued_documents")
}

model Appointment {
  id                 String               @id @default(uuid())
  clinicId           String
  patientId          String
  doctorId           String
  branchId           String
  roomId             String?
  startTime          DateTime
  endTime            DateTime
  status             AppointmentStatus    @default(SCHEDULED)
  color              String?
  notes              String?
  cancellationReason String?
  createdByUserId    String?
  isDeleted          Boolean              @default(false)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  completedAt        DateTime?
  confirmedAt        DateTime?
  source             AppointmentSource    @default(MANUAL)
  startedAt          DateTime?
  services           AppointmentService[]
  branch             Branch               @relation(fields: [branchId], references: [id])
  createdBy          User?                @relation("CreatedAppointments", fields: [createdByUserId], references: [id])
  doctor             User                 @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient            Patient              @relation(fields: [patientId], references: [id])
  room               Room?                @relation(fields: [roomId], references: [id])
  files              File[]
  medicalRecord      MedicalRecord?
  patientDiaries     PatientDiary[]
  invoices           Invoice[]
  promotionUsages    PromotionUsage[]
  doctorPayments     DoctorPayment[]
  labOrders          LabOrder[]

  @@map("clin_appointments")
}

model WidgetBooking {
  id               String              @id @default(uuid())
  clinicId         String
  patientName      String
  patientPhone     String
  patientEmail     String?
  patientId        String?
  serviceId        String?
  doctorId         String?
  preferredDate    DateTime
  preferredTime    String
  status           WidgetBookingStatus @default(NEW)
  ipAddress        String?
  createdAt        DateTime            @default(now())
  processedAt      DateTime?
  confirmationCode String?
  patient          Patient?            @relation(fields: [patientId], references: [id])
  service          Service?            @relation(fields: [serviceId], references: [id])

  @@map("clin_widget_bookings")
}

model DoctorSchedule {
  id        String                @id @default(uuid())
  clinicId  String
  doctorId  String
  branchId  String
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean               @default(true)
  updatedAt DateTime              @updatedAt
  breaks    DoctorScheduleBreak[]
  branch    Branch                @relation(fields: [branchId], references: [id])
  doctor    User                  @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, branchId, dayOfWeek])
  @@map("clin_doctor_schedules")
}

model DoctorScheduleBreak {
  id         String         @id @default(uuid())
  scheduleId String
  startTime  String
  endTime    String
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id])

  @@map("clin_doctor_schedule_breaks")
}

model ScheduleException {
  id          String                @id @default(uuid())
  clinicId    String
  doctorId    String
  branchId    String?
  date        DateTime              @db.Date
  isAvailable Boolean               @default(false)
  startTime   String?
  endTime     String?
  reason      String?
  createdAt   DateTime              @default(now())
  type        ScheduleExceptionType @default(CUSTOM_HOURS)
  branch      Branch?               @relation(fields: [branchId], references: [id])
  doctor      User                  @relation(fields: [doctorId], references: [id])

  @@map("clin_schedule_exceptions")
}

model ServiceCategory {
  id        String    @id @default(uuid())
  clinicId  String
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  services  Service[]

  @@map("clin_service_categories")
}

model Service {
  id                         String                      @id @default(uuid())
  clinicId                   String
  categoryId                 String?
  name                       String
  code                       String?
  price                      Decimal                     @db.Decimal(10, 2)
  durationMinutes            Int                         @default(30)
  isActive                   Boolean                     @default(true)
  isDeleted                  Boolean                     @default(false)
  deletedAt                  DateTime?
  createdAt                  DateTime                    @default(now())
  color                      String?
  description                String?
  appointmentServices        AppointmentService[]
  branchPrices               ServiceBranchPrice[]
  category                   ServiceCategory?            @relation(fields: [categoryId], references: [id])
  treatmentPlanItems         TreatmentPlanItem[]
  treatmentPlanTemplateItems TreatmentPlanTemplateItem[]
  widgetBookings             WidgetBooking[]
  consultInvoiceItems        ConsultInvoiceItem[]
  invoiceItems               InvoiceItem[]
  promotionServices          PromotionService[]
  serviceMaterials           ServiceMaterial[]

  @@map("clin_services")
}

model ServiceBranchPrice {
  serviceId String
  branchId  String
  price     Decimal   @db.Decimal(10, 2)
  updatedAt DateTime  @updatedAt
  validFrom DateTime? @db.Date
  validTo   DateTime? @db.Date
  branch    Branch    @relation(fields: [branchId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])

  @@id([serviceId, branchId])
  @@map("clin_service_branch_prices")
}

model AppointmentService {
  id            String      @id @default(uuid())
  appointmentId String
  serviceId     String
  quantity      Int         @default(1)
  price         Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  service       Service     @relation(fields: [serviceId], references: [id])

  @@map("clin_appointment_services")
}

model TreatmentPlanTemplate {
  id        String                      @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
  isFolder  Boolean                     @default(false)
  sortOrder Int                         @default(0)
  isActive  Boolean                     @default(true)
  createdAt DateTime                    @default(now())
  items     TreatmentPlanTemplateItem[]
  parent    TreatmentPlanTemplate?      @relation("TplFolder", fields: [parentId], references: [id])
  children  TreatmentPlanTemplate[]     @relation("TplFolder")

  @@map("clin_treatment_plan_templates")
}

model TreatmentPlanTemplateItem {
  id         String                @id @default(uuid())
  templateId String
  serviceId  String
  quantity   Int                   @default(1)
  sortOrder  Int                   @default(0)
  service    Service               @relation(fields: [serviceId], references: [id])
  template   TreatmentPlanTemplate @relation(fields: [templateId], references: [id])

  @@map("clin_treatment_plan_template_items")
}

model TreatmentPlan {
  id              String              @id @default(uuid())
  clinicId        String
  patientId       String
  doctorId        String
  name            String
  status          TreatmentPlanStatus @default(DRAFT)
  startDate       DateTime?           @db.Date
  endDate         DateTime?           @db.Date
  notes           String?
  isDeleted       Boolean             @default(false)
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  items           TreatmentPlanItem[]
  doctor          User                @relation(fields: [doctorId], references: [id])
  patient         Patient             @relation(fields: [patientId], references: [id])
  consultInvoices ConsultInvoice[]

  @@map("clin_treatment_plans")
}

model TreatmentPlanItem {
  id          String        @id @default(uuid())
  planId      String
  serviceId   String
  toothNumber Int?
  quantity    Int           @default(1)
  price       Decimal       @db.Decimal(10, 2)
  discount    Decimal       @default(0) @db.Decimal(10, 2)
  isDone      Boolean       @default(false)
  doneAt      DateTime?
  sortOrder   Int           @default(0)
  plan        TreatmentPlan @relation(fields: [planId], references: [id])
  service     Service       @relation(fields: [serviceId], references: [id])

  @@map("clin_treatment_plan_items")
}

model DiagnosisCategory {
  id        String              @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
  sortOrder Int                 @default(0)
  isActive  Boolean             @default(true)
  diagnoses Diagnosis[]
  parent    DiagnosisCategory?  @relation("DiagnosisFolder", fields: [parentId], references: [id])
  children  DiagnosisCategory[] @relation("DiagnosisFolder")

  @@map("clin_diagnosis_categories")
}

model Diagnosis {
  id              String                   @id @default(uuid())
  clinicId        String
  categoryId      String?
  code            String?
  name            String
  isActive        Boolean                  @default(true)
  category        DiagnosisCategory?       @relation(fields: [categoryId], references: [id])
  recordDiagnoses MedicalRecordDiagnosis[]

  @@map("clin_diagnoses")
}

model MedicalRecordDiagnosis {
  id              String        @id @default(uuid())
  medicalRecordId String
  diagnosisId     String
  isPrimary       Boolean       @default(false)
  diagnosis       Diagnosis     @relation(fields: [diagnosisId], references: [id])
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])

  @@map("clin_medical_record_diagnoses")
}

model ExaminationTemplate {
  id        String                       @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
  isFolder  Boolean                      @default(false)
  sortOrder Int                          @default(0)
  isActive  Boolean                      @default(true)
  sections  ExaminationTemplateSection[]
  parent    ExaminationTemplate?         @relation("ExamFolder", fields: [parentId], references: [id])
  children  ExaminationTemplate[]        @relation("ExamFolder")

  @@map("clin_examination_templates")
}

model ExaminationTemplateSection {
  id         String              @id @default(uuid())
  templateId String
  name       String
  content    String?
  sortOrder  Int                 @default(0)
  template   ExaminationTemplate @relation(fields: [templateId], references: [id])

  @@map("clin_examination_template_sections")
}

model DiaryTemplate {
  id        String          @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
  isFolder  Boolean         @default(false)
  content   String?
  sortOrder Int             @default(0)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  parent    DiaryTemplate?  @relation("DiaryFolder", fields: [parentId], references: [id])
  children  DiaryTemplate[] @relation("DiaryFolder")

  @@map("clin_diary_templates")
}

model DentalChart {
  id              String               @id @default(uuid())
  clinicId        String
  patientId       String
  toothNumber     Int
  status          ToothStatus          @default(HEALTHY)
  notes           String?
  updatedByUserId String?
  updatedAt       DateTime             @updatedAt
  buccalStatus    ToothStatus?
  distalStatus    ToothStatus?
  hasSensitivity  Boolean?
  lingualStatus   ToothStatus?
  mesialStatus    ToothStatus?
  mobility        Int?
  occlusalStatus  ToothStatus?
  toothColor      String?
  patient         Patient              @relation(fields: [patientId], references: [id])
  history         DentalChartHistory[]

  @@unique([patientId, toothNumber])
  @@map("clin_dental_chart")
}

model DentalChartHistory {
  id              String      @id @default(uuid())
  dentalChartId   String
  oldStatus       ToothStatus
  newStatus       ToothStatus
  notes           String?
  changedByUserId String?
  createdAt       DateTime    @default(now())
  dentalChart     DentalChart @relation(fields: [dentalChartId], references: [id])

  @@map("clin_dental_chart_history")
}

model MedicalRecord {
  id              String                   @id @default(uuid())
  clinicId        String
  patientId       String
  appointmentId   String?                  @unique
  recordType      RecordType               @default(EXAMINATION)
  complaints      String?
  anamnesis       String?
  treatmentPlan   String?
  notes           String?
  createdByUserId String?
  isDeleted       Boolean                  @default(false)
  deletedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  diagnoses       MedicalRecordDiagnosis[]
  appointment     Appointment?             @relation(fields: [appointmentId], references: [id])
  createdBy       User?                    @relation(fields: [createdByUserId], references: [id])
  patient         Patient                  @relation(fields: [patientId], references: [id])

  @@map("clin_medical_records")
}

model PatientDiary {
  id            String       @id @default(uuid())
  clinicId      String
  patientId     String
  doctorId      String
  appointmentId String?
  content       String
  recordDate    DateTime     @db.Date
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  doctor        User         @relation(fields: [doctorId], references: [id])
  patient       Patient      @relation(fields: [patientId], references: [id])

  @@map("clin_patient_diary")
}

model File {
  id               String       @id @default(uuid())
  clinicId         String
