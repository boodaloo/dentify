generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  OWNER
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  ACCOUNTANT
  LAB_TECHNICIAN
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  MANUAL
  WIDGET
  CALL
  WALK_IN
}

enum ContactType {
  PHONE
  EMAIL
  ADDRESS
}

enum RecordType {
  EXAMINATION
  TREATMENT
  CONSULTATION
}

enum ToothStatus {
  HEALTHY
  CARIES
  FILLED
  CROWN
  EXTRACTED
  IMPLANT
  BRIDGE
  MISSING
  PROSTHESIS
  VENEER
  INLAY
}

enum FileType {
  XRAY
  PHOTO
  DOCUMENT
  OTHER
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  BALANCE
  INSURANCE
}

enum BalanceTransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum BonusTransactionType {
  EARNED
  SPENT
  EXPIRED
  MANUAL
}

enum BonusRuleType {
  PERCENT
  FIXED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PromotionType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  BONUS_MULTIPLY
  FREE_SERVICE
}

enum ContractorType {
  SUPPLIER
  LAB
  OTHER
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum WidgetBookingStatus {
  NEW
  CONFIRMED
  CANCELLED
}

enum TreatmentPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LabOrderStatus {
  NEW
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum LabType {
  LAB
  TECHNICIAN
}

enum InsuranceType {
  DMS
  OMS
}

enum SalaryType {
  FIXED
  PERCENT
  MIXED
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum NotificationEventType {
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
  BIRTHDAY
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum RelativeType {
  PARENT
  SPOUSE
  CHILD
  GUARDIAN
  OTHER
}

enum CashFlowDirection {
  INCOME
  EXPENSE
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallResult {
  ANSWERED
  MISSED
  BUSY
  VOICEMAIL
}

enum PatientReferralSource {
  INTERNET
  RECOMMENDATION
  ADVERTISEMENT
  SOCIAL_MEDIA
  WALK_IN
  OTHER
}

enum SubscriptionPlanCode {
  SOLO
  CLINIC
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ============================================================
// CORE — Клиника
// ============================================================

model Clinic {
  id        String   @id @default(uuid())
  name      String
  legalName String?
  inn       String?
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches        Branch[]
  userClinics     UserClinic[]
  specializations Specialization[]
  patients        Patient[]
  settings        ClinicSettings?
  widgetSettings  WidgetSettings?
  subscription    Subscription?

  @@map("core_clinics")
}

model ClinicSettings {
  id                         String   @id @default(uuid())
  clinicId                   String   @unique
  clinic                     Clinic   @relation(fields: [clinicId], references: [id])
  timezone                   String   @default("Europe/Moscow")
  currency                   String   @default("RUB")
  dateFormat                 String   @default("DD.MM.YYYY")
  timeFormat                 String   @default("24h")
  appointmentDurationDefault Int      @default(30)
  workingHoursStart          String   @default("09:00")
  workingHoursEnd            String   @default("21:00")
  updatedAt                  DateTime @updatedAt

  @@map("core_clinic_settings")
}

model WidgetSettings {
  clinicId            String   @id
  clinic              Clinic   @relation(fields: [clinicId], references: [id])
  apiKey              String   @unique @default(uuid())
  allowedDomains      String[]
  enabled             Boolean  @default(false)
  theme               Json?
  showDoctors         Boolean  @default(true)
  availableServiceIds String[]
  updatedAt           DateTime @updatedAt

  @@map("core_widget_settings")
}

// ============================================================
// CORE — Филиалы и кабинеты
// ============================================================

model Branch {
  id                String    @id @default(uuid())
  clinicId          String
  clinic            Clinic    @relation(fields: [clinicId], references: [id])
  name              String
  shortCode         String?
  address           String?
  phone             String?
  color             String?
  isMain            Boolean   @default(false)
  isActive          Boolean   @default(true)
  workingHoursStart String?
  workingHoursEnd   String?
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rooms                Room[]
  workingHours         BranchWorkingHours[]
  userBranches         UserBranch[]
  appointments         Appointment[]
  doctorSchedules      DoctorSchedule[]
  scheduleExceptions   ScheduleException[]
  serviceBranchPrices  ServiceBranchPrice[]
  materialStock        MaterialStock[]
  stockMovements       StockMovement[]
  stockReceipts        StockReceipt[]
  calls                Call[]
  workTimes            EmployeeWorkTime[]
  cashFlowTransactions CashFlowTransaction[]

  @@map("core_branches")
}

model BranchWorkingHours {
  id        String  @id @default(uuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])
  dayOfWeek Int     // 0=Пн, 6=Вс
  isOpen    Boolean @default(true)
  startTime String  @default("09:00")
  endTime   String  @default("21:00")

  @@unique([branchId, dayOfWeek])
  @@map("core_branch_working_hours")
}

model Room {
  id        String   @id @default(uuid())
  clinicId  String
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  appointments Appointment[]

  @@map("core_rooms")
}

// ============================================================
// CORE — Пользователи (глобальные)
// ============================================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String
  phone          String?
  avatarUrl      String?
  birthDate      DateTime?
  title          String?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Членство в клиниках
  userClinics UserClinic[]

  // Связи с данными (контекст клиники определяется через clinicId на каждой записи)
  userBranches             UserBranch[]
  patientComments          PatientComment[]
  appointments             Appointment[]        @relation("DoctorAppointments")
  createdAppointments      Appointment[]        @relation("CreatedAppointments")
  doctorSchedules          DoctorSchedule[]
  scheduleExceptions       ScheduleException[]
  medicalRecords           MedicalRecord[]
  patientDiaries           PatientDiary[]
  uploadedFiles            File[]
  createdInvoices          Invoice[]
  receivedPayments         Payment[]
  balanceTransactions      BalanceTransaction[]
  bonusTransactions        BonusTransaction[]
  stockMovements           StockMovement[]
  createdStockReceipts     StockReceipt[]
  salarySettings           EmployeeSalarySettings[]
  workTimes                EmployeeWorkTime[]
  doctorPayments           DoctorPayment[]      @relation("DoctorPaymentUser")
  createdDoctorPayments    DoctorPayment[]      @relation("DoctorPaymentCreatedBy")
  reminders                Reminder[]
  handledCalls             Call[]
  treatmentPlans           TreatmentPlan[]
  createdConsultInvoices   ConsultInvoice[]
  cashFlowTransactions     CashFlowTransaction[]
  createdLabOrders         LabOrder[]
  createdLabInvoices       LabInvoice[]
  issuedDocuments          IssuedDocument[]
  patientDoctors           PatientDoctor[]

  @@map("core_users")
}

// Членство пользователя в конкретной клинике (роль, специализация — всё клинико-специфичное)
model UserClinic {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  clinicId         String
  clinic           Clinic         @relation(fields: [clinicId], references: [id])
  role             UserRole       @default(DOCTOR)
  isOwner          Boolean        @default(false)
  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  color            String?
  isActive         Boolean        @default(true)
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  joinedAt         DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, clinicId])
  @@map("core_user_clinics")
}

model UserBranch {
  userId      String
  branchId    String
  user        User    @relation(fields: [userId], references: [id])
  branch      Branch  @relation(fields: [branchId], references: [id])
  isDefault   Boolean @default(false)
  accessLevel String  @default("full")

  @@id([userId, branchId])
  @@map("core_user_branches")
}

// ============================================================
// CORE — Специализации
// ============================================================

model Specialization {
  id        String   @id @default(uuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userClinics    UserClinic[]
  patientDoctors PatientDoctor[]
  salarySettings EmployeeSalarySettings[]

  @@map("core_specializations")
}

// ============================================================
// CORE — Пациенты
// ============================================================

model Patient {
  id              String                 @id @default(uuid())
  clinicId        String
  clinic          Clinic                 @relation(fields: [clinicId], references: [id])
  patientNumber   String?                // читаемый номер карты: П-00123
  firstName       String
  lastName        String
  middleName      String?
  birthDate       DateTime?
  gender          Gender?
  allergies       String?
  notes           String?
  snils           String?
  inn             String?
  passportSeries  String?
  passportNumber  String?
  referralSource  PatientReferralSource?
  homeBranchId    String?
  loyaltyTierId   String?
  loyaltyTier     LoyaltyTier?           @relation(fields: [loyaltyTierId], references: [id])
  createdByUserId String?
  isDeleted       Boolean                @default(false)
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  contacts             PatientContact[]
  comments             PatientComment[]
  doctors              PatientDoctor[]
  relatives            PatientRelative[]    @relation("PatientRelatives")
  relativeOf           PatientRelative[]    @relation("RelativeAsPatient")
  groupMemberships     PatientGroupMember[]
  insurances           PatientInsurance[]
  appointments         Appointment[]
  medicalRecords       MedicalRecord[]
  patientDiaries       PatientDiary[]
  dentalChart          DentalChart[]
  files                File[]
  invoices             Invoice[]
  balance              Balance?
  balanceTransactions  BalanceTransaction[]
  bonuses              Bonus?
  bonusTransactions    BonusTransaction[]
  promotionUsages      PromotionUsage[]
  widgetBookings       WidgetBooking[]
  treatmentPlans       TreatmentPlan[]
  consultInvoices      ConsultInvoice[]
  labOrders            LabOrder[]
  notificationLogs     NotificationLog[]
  reminders            Reminder[]
  calls                Call[]
  issuedDocuments      IssuedDocument[]
  labels               PatientLabelAssignment[]

  @@unique([clinicId, patientNumber])
  @@map("core_patients")
}

model PatientContact {
  id        String      @id @default(uuid())
  clinicId  String
  patientId String
  patient   Patient     @relation(fields: [patientId], references: [id])
  type      ContactType
  value     String
  label     String?
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@map("core_patient_contacts")
}

model PatientComment {
  id        String   @id @default(uuid())
  clinicId  String
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("core_patient_comments")
}

model PatientLabel {
  id          String                  @id @default(uuid())
  clinicId    String
  name        String
  color       String                  @default("#14919B")
  textColor   String                  @default("#ffffff")
  isSystem    Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  assignments PatientLabelAssignment[]

  @@unique([clinicId, name])
  @@map("core_patient_labels")
}

model PatientLabelAssignment {
  id        String       @id @default(uuid())
  clinicId  String
  patientId String
  patient   Patient      @relation(fields: [patientId], references: [id])
  labelId   String
  label     PatientLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  assignedAt DateTime    @default(now())

  @@unique([patientId, labelId])
  @@map("core_patient_label_assignments")
}

model PatientDoctor {
  id               String         @id @default(uuid())
  clinicId         String
  patientId        String
  patient          Patient        @relation(fields: [patientId], references: [id])
  doctorId         String
  doctor           User           @relation(fields: [doctorId], references: [id])
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  isActive         Boolean        @default(true)
  assignedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())

  @@map("core_patient_doctors")
}

model PatientRelative {
  id                String       @id @default(uuid())
  clinicId          String
  patientId         String
  patient           Patient      @relation("PatientRelatives", fields: [patientId], references: [id])
  relativeType      RelativeType
  name              String
  phone             String?
  email             String?
  isGuardian        Boolean      @default(false)
  notes             String?
  relativePatientId String?
  relativePatient   Patient?     @relation("RelativeAsPatient", fields: [relativePatientId], references: [id])
  createdAt         DateTime     @default(now())

  @@map("core_patient_relatives")
}

model PatientGroup {
  id            String       @id @default(uuid())
  clinicId      String
  name          String
  discountType  DiscountType @default(PERCENT)
  discountValue Decimal      @db.Decimal(5, 2)
  color         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  members PatientGroupMember[]

  @@map("core_patient_groups")
}

model PatientGroupMember {
  groupId   String
  patientId String
  group     PatientGroup @relation(fields: [groupId], references: [id])
  patient   Patient      @relation(fields: [patientId], references: [id])
  addedAt   DateTime     @default(now())

  @@id([groupId, patientId])
  @@map("core_patient_group_members")
}

// ============================================================
// CORE — Звонки
// ============================================================

model Call {
  id              String        @id @default(uuid())
  clinicId        String
  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])
  patientId       String?
  patient         Patient?      @relation(fields: [patientId], references: [id])
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  direction       CallDirection
  result          CallResult
  phone           String
  durationSeconds Int?
  notes           String?
  recordingUrl    String?
  calledAt        DateTime
  createdAt       DateTime      @default(now())

  @@map("core_calls")
}

// ============================================================
// CORE — Выданные документы
// ============================================================

model IssuedDocument {
  id              String    @id @default(uuid())
  clinicId        String
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id])
  docType         String
  docNumber       String?
  issuedAt        DateTime  @default(now())
  validTo         DateTime?
  fileKey         String?
  notes           String?
  createdByUserId String?
  createdBy       User?     @relation(fields: [createdByUserId], references: [id])

  @@map("core_issued_documents")
}

// ============================================================
// CLINICAL — Расписание и приёмы
// ============================================================

model Appointment {
  id                 String            @id @default(uuid())
  clinicId           String
  patientId          String
  patient            Patient           @relation(fields: [patientId], references: [id])
  doctorId           String
  doctor             User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  branchId           String
  branch             Branch            @relation(fields: [branchId], references: [id])
  roomId             String?
  room               Room?             @relation(fields: [roomId], references: [id])
  startTime          DateTime
  endTime            DateTime
  status             AppointmentStatus @default(SCHEDULED)
  source             AppointmentSource @default(MANUAL)
  color              String?
  notes              String?
  cancellationReason String?
  confirmedAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdByUserId    String?
  createdBy          User?             @relation("CreatedAppointments", fields: [createdByUserId], references: [id])
  isDeleted          Boolean           @default(false)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  services        AppointmentService[]
  medicalRecord   MedicalRecord?
  patientDiaries  PatientDiary[]
  files           File[]
  invoices        Invoice[]
  promotionUsages PromotionUsage[]
  labOrders       LabOrder[]
  doctorPayments  DoctorPayment[]

  @@map("clin_appointments")
}

model WidgetBooking {
  id                String              @id @default(uuid())
  clinicId          String
  patientName       String
  patientPhone      String
  patientEmail      String?
  patientId         String?
  patient           Patient?            @relation(fields: [patientId], references: [id])
  serviceId         String?
  service           Service?            @relation(fields: [serviceId], references: [id])
  doctorId          String?
  preferredDate     DateTime
  preferredTime     String
  status            WidgetBookingStatus @default(NEW)
  confirmationCode  String?
  ipAddress         String?
  createdAt         DateTime            @default(now())
  processedAt       DateTime?

  @@map("clin_widget_bookings")
}

model DoctorSchedule {
  id        String   @id @default(uuid())
  clinicId  String
  doctorId  String
  doctor    User     @relation(fields: [doctorId], references: [id])
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean  @default(true)
  updatedAt DateTime @updatedAt

  breaks DoctorScheduleBreak[]

  @@unique([doctorId, branchId, dayOfWeek])
  @@map("clin_doctor_schedules")
}

model DoctorScheduleBreak {
  id         String         @id @default(uuid())
  scheduleId String
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id])
  startTime  String
  endTime    String

  @@map("clin_doctor_schedule_breaks")
}

enum ScheduleExceptionType {
  DAY_OFF
  NO_SHOW
  SICK_LEAVE
  VACATION
  CUSTOM_HOURS
}

model ScheduleException {
  id          String                @id @default(uuid())
  clinicId    String
  doctorId    String
  doctor      User                  @relation(fields: [doctorId], references: [id])
  branchId    String?
  branch      Branch?               @relation(fields: [branchId], references: [id])
  date        DateTime              @db.Date
  isAvailable Boolean               @default(false)
  type        ScheduleExceptionType @default(CUSTOM_HOURS)
  startTime   String?
  endTime     String?
  reason      String?
  createdAt   DateTime              @default(now())

  @@map("clin_schedule_exceptions")
}

// ============================================================
// CLINICAL — Услуги и прайс-лист
// ============================================================

model ServiceCategory {
  id        String    @id @default(uuid())
  clinicId  String
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  services Service[]

  @@map("clin_service_categories")
}

model Service {
  id              String           @id @default(uuid())
  clinicId        String
  categoryId      String?
  category        ServiceCategory? @relation(fields: [categoryId], references: [id])
  name            String
  code            String?
  description     String?
  color           String?
  price           Decimal          @db.Decimal(10, 2)
  durationMinutes Int              @default(30)
  isActive        Boolean          @default(true)
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())

  branchPrices               ServiceBranchPrice[]
  appointmentServices        AppointmentService[]
  widgetBookings             WidgetBooking[]
  promotionServices          PromotionService[]
  serviceMaterials           ServiceMaterial[]
  treatmentPlanTemplateItems TreatmentPlanTemplateItem[]
  treatmentPlanItems         TreatmentPlanItem[]
  consultInvoiceItems        ConsultInvoiceItem[]
  invoiceItems               InvoiceItem[]

  @@map("clin_services")
}

model ServiceBranchPrice {
  serviceId String
  branchId  String
  service   Service  @relation(fields: [serviceId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])
  price     Decimal  @db.Decimal(10, 2)
  validFrom DateTime? @db.Date
  validTo   DateTime? @db.Date
  updatedAt DateTime @updatedAt

  @@id([serviceId, branchId])
  @@map("clin_service_branch_prices")
}

model AppointmentService {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  quantity      Int         @default(1)
  price         Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  @@map("clin_appointment_services")
}

// ============================================================
// CLINICAL — Планы лечения
// ============================================================

model TreatmentPlanTemplate {
  id        String                  @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
  parent    TreatmentPlanTemplate?  @relation("TplFolder", fields: [parentId], references: [id])
  children  TreatmentPlanTemplate[] @relation("TplFolder")
  isFolder  Boolean                 @default(false)
  sortOrder Int                     @default(0)
  isActive  Boolean                 @default(true)
  createdAt DateTime                @default(now())

  items TreatmentPlanTemplateItem[]

  @@map("clin_treatment_plan_templates")
}

model TreatmentPlanTemplateItem {
  id         String                @id @default(uuid())
  templateId String
  template   TreatmentPlanTemplate @relation(fields: [templateId], references: [id])
  serviceId  String
  service    Service               @relation(fields: [serviceId], references: [id])
  quantity   Int                   @default(1)
  sortOrder  Int                   @default(0)

  @@map("clin_treatment_plan_template_items")
}

model TreatmentPlan {
  id              String              @id @default(uuid())
  clinicId        String
  patientId       String
  patient         Patient             @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          User                @relation(fields: [doctorId], references: [id])
  name            String
  status          TreatmentPlanStatus @default(DRAFT)
  startDate       DateTime?           @db.Date
  endDate         DateTime?           @db.Date
  notes           String?
  isDeleted       Boolean             @default(false)
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items           TreatmentPlanItem[]
  consultInvoices ConsultInvoice[]

  @@map("clin_treatment_plans")
}

model TreatmentPlanItem {
  id          String        @id @default(uuid())
  planId      String
  plan        TreatmentPlan @relation(fields: [planId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  toothNumber Int?
  quantity    Int           @default(1)
  price       Decimal       @db.Decimal(10, 2)
  discount    Decimal       @default(0) @db.Decimal(10, 2)
  isDone      Boolean       @default(false)
  doneAt      DateTime?
  sortOrder   Int           @default(0)

  @@map("clin_treatment_plan_items")
}

// ============================================================
// CLINICAL — Диагнозы
// ============================================================

model DiagnosisCategory {
  id        String              @id @default(uuid())
  clinicId  String
  name      String
  parentId  String?
