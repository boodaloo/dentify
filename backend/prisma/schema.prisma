  clinicId        String
  materialId      String
  material        Material @relation(fields: [materialId], references: [id])
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])
  quantity        Decimal  @default(0) @db.Decimal(10, 3)
  lastUpdatedAt   DateTime @updatedAt
  updatedByUserId String?

  @@unique([materialId, branchId])
  @@map("inv_material_stock")
}

model StockMovement {
  id                 String            @id @default(uuid())
  clinicId           String
  materialId         String
  material           Material          @relation(fields: [materialId], references: [id])
  branchId           String
  branch             Branch            @relation(fields: [branchId], references: [id])
  type               StockMovementType
  quantity           Decimal           @db.Decimal(10, 3)
  quantityBefore     Decimal           @db.Decimal(10, 3)
  quantityAfter      Decimal           @db.Decimal(10, 3)
  sourceType         String?
  sourceId           String?
  contractorId       String?
  contractor         Contractor?       @relation(fields: [contractorId], references: [id])
  transferToBranchId String?
  notes              String?
  createdByUserId    String?
  createdBy          User?             @relation(fields: [createdByUserId], references: [id])
  createdAt          DateTime          @default(now())

  @@map("inv_stock_movements")
}

model StockReceipt {
  id              String      @id @default(uuid())
  clinicId        String
  branchId        String
  branch          Branch      @relation(fields: [branchId], references: [id])
  contractorId    String?
  contractor      Contractor? @relation(fields: [contractorId], references: [id])
  receiptNumber   String?
  receiptDate     DateTime    @db.Date
  totalAmount     Decimal     @db.Decimal(10, 2)
  notes           String?
  createdByUserId String?
  createdBy       User?       @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime    @default(now())

  items StockReceiptItem[]

  @@map("inv_stock_receipts")
}

model StockReceiptItem {
  id         String       @id @default(uuid())
  receiptId  String
  receipt    StockReceipt @relation(fields: [receiptId], references: [id])
  materialId String
  material   Material     @relation(fields: [materialId], references: [id])
  quantity   Decimal      @db.Decimal(10, 3)
  price      Decimal      @db.Decimal(10, 2)
  amount     Decimal      @db.Decimal(10, 2)
  createdAt  DateTime     @default(now())

  @@map("inv_stock_receipt_items")
}

model ServiceMaterial {
  id         String   @id @default(uuid())
  clinicId   String
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Decimal  @db.Decimal(10, 3)
  isRequired Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([serviceId, materialId])
  @@map("inv_service_materials")
}

// ============================================================
// SAAS — Подписки (биллинг платформы Orisios)
// ============================================================

model SubscriptionPlan {
  id           String               @id @default(uuid())
  code         SubscriptionPlanCode @unique
  name         String
  maxDoctors   Int?
  maxBranches  Int?
  priceMonthly Decimal              @db.Decimal(10, 2)
  priceYearly  Decimal              @db.Decimal(10, 2)
  features     Json?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  subscriptions Subscription[]

  @@map("saas_subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  clinicId             String             @unique
  clinic               Clinic             @relation(fields: [clinicId], references: [id])
  planId               String
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("saas_subscriptions")
}

// ============================================================
// SYSTEM — Аудит лог
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  clinicId   String?
  userId     String?
  entityType String   // "Patient", "Invoice", "MedicalRecord", etc.
  entityId   String
  action     String   // "CREATE", "UPDATE", "DELETE"
  changes    Json?    // { field: { old: ..., new: ... } }
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([clinicId, createdAt])
  @@map("sys_audit_logs")
}

// ============================================================
// CLINICAL — Visit Form Templates
// ============================================================

model VisitFormTemplate {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  role      String   // "DOCTOR" | "ADMIN" | "ALL"
  isDefault Boolean  @default(false)
  blocks    Json     // [{type, order, visible, required, label}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clin_visit_form_templates")
}
